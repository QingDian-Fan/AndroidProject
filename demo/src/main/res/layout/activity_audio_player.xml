<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_audio_player"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    tools:context=".ui.activity.AudioPlayerActivity">

    <!-- 封面 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCover"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_audio_cover" />

            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_centerInParent="true"
                android:contentDescription="@null"
                android:src="@drawable/ic_audio_music_note" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/audio_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        tools:text="未知音频" />

    <!-- 副标题/状态 -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/audio_text_secondary"
        android:textSize="14sp"
        tools:text="正在播放" />

    <!-- 占位：把进度与控制条推到底部 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 进度条 -->
    <SeekBar
        android:id="@+id/sbProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="-4dp"
        android:layout_marginEnd="-4dp"
        android:maxHeight="4dp"
        android:minHeight="4dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:progressDrawable="@drawable/seekbar_audio_progress"
        android:splitTrack="false"
        android:thumb="@drawable/seekbar_audio_thumb"
        android:thumbOffset="7dp" />

    <!-- 时间行 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">

        <!-- 当前时间 -->
        <TextView
            android:id="@+id/tvCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textColor="@color/audio_text_secondary"
            android:textSize="12sp"
            tools:text="00:00" />

        <!-- 总时长 -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:textColor="@color/audio_text_secondary"
            android:textSize="12sp"
            tools:text="03:45" />

    </RelativeLayout>

    <!-- 控制行 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="56dp">

        <!-- 播放/暂停 -->
        <ImageView
            android:id="@+id/ivPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_audio_play_button"
            android:contentDescription="@null"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_audio_play" />

        <!-- 快退 15s -->
        <ImageView
            android:id="@+id/ivRewind"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="48dp"
            android:layout_toStartOf="@id/ivPlayPause"
            android:contentDescription="@null"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_audio_rewind" />

        <!-- 快进 15s -->
        <ImageView
            android:id="@+id/ivForward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="48dp"
            android:layout_toEndOf="@id/ivPlayPause"
            android:contentDescription="@null"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_audio_forward" />

    </RelativeLayout>

</LinearLayout>
