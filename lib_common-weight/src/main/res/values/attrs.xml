<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 设置栏 -->
    <declare-styleable name="SettingBar">
        <!-- 左边 -->
        <attr name="bar_leftText" format="string"/>
        <attr name="bar_leftTextColor" format="color" />
        <attr name="bar_leftTextSize" format="dimension" />
        <attr name="bar_leftTextHint" format="string"/>
        <attr name="bar_leftDrawable" format="reference" />
        <attr name="bar_leftDrawablePadding" format="dimension" />
        <attr name="bar_leftDrawableSize" format="dimension" />
        <attr name="bar_leftDrawableTint" format="color" />
        <!-- 右边 -->
        <attr name="bar_rightText" format="string" />
        <attr name="bar_rightTextColor" format="color" />
        <attr name="bar_rightTextSize" format="dimension" />
        <attr name="bar_rightTextHint" format="string"/>
        <attr name="bar_rightDrawable" format="reference" />
        <attr name="bar_rightDrawablePadding" format="dimension" />
        <attr name="bar_rightDrawableSize" format="dimension" />
        <attr name="bar_rightDrawableTint" format="color" />
        <!-- 分割线 -->
        <attr name="bar_lineVisible" format="boolean" />
        <attr name="bar_lineDrawable" format="reference|color" />
        <attr name="bar_lineSize" format="dimension" />
        <attr name="bar_lineMargin" format="dimension" />
    </declare-styleable>

    <declare-styleable name="RevealLayout">
        <attr format="reference" name="rl_checkedLayout"/>
        <attr format="reference" name="rl_uncheckedLayout"/>
        <attr format="boolean|reference" name="rl_checked"/>
        <attr format="integer|reference" name="rl_animDuration"/>
        <attr format="boolean|reference" name="rl_checkWithExpand"/>
        <attr format="boolean|reference" name="rl_uncheckWithExpand"/>
        <attr format="boolean|reference" name="rl_allowRevert"/>
        <attr format="boolean|reference" name="rl_hideBackView"/>
    </declare-styleable>

    <declare-styleable name="HeartView">
        <attr format="enum" name="heart_sizeBasic">
            <enum name="none" value="0"/>
            <enum name="width" value="1"/>
            <enum name="height" value="2"/>
        </attr>
        <attr format="reference|color" name="heart_color"/>
        <attr format="reference|color" name="heart_edgeColor"/>
        <attr format="reference|float" name="heart_centerX"/>
        <attr format="reference|float" name="heart_centerY"/>
        <attr format="reference|float" name="heart_radius"/>
        <attr format="reference|color" name="heart_strokeColor"/>
        <attr format="reference|dimension" name="heart_strokeWidth"/>
    </declare-styleable>
    <declare-styleable name="CollectView">
        <attr name="cv_uncheckedColor" format="color|reference" />
    </declare-styleable>

    <declare-styleable name="TextViewExpandableAnimation">
        <attr name="tvea_expandLines" format="integer" />
        <attr name="tvea_shrinkBitmap" format="reference" />
        <attr name="tvea_expandBitmap" format="reference" />
        <attr name="tvea_textStateColor" format="color" />
        <attr name="tvea_textContentColor" format="color" />
        <attr name="tvea_textContentSize" format="dimension" />
        <attr name="tvea_textShrink" format="string" />
        <attr name="tvea_textExpand" format="string" />
    </declare-styleable>

    <declare-styleable name="AutoSizeAppCompatTextView">
        <attr name="minTextSize" format="dimension"/>
        <attr name="maxTextSize" format="dimension"/>
        <attr name="stepGranularity" format="dimension"/>
    </declare-styleable>
    <declare-styleable name="PercentImageView">
        <attr name="piv_basics" format="enum">
            <enum name="width" value="0" />
            <enum name="height" value="1" />
        </attr>

        <!-- 百分比模式 -->
        <attr name="piv_percent" format="float" />

        <!-- 新增：宽高比例（如 16/9=1.7777） -->
        <attr name="piv_aspectRatio" format="float" />
    </declare-styleable>
    <declare-styleable name="DrawableTextView">
        <attr name="drawable_width" format="dimension"/>
        <attr name="drawable_height" format="dimension"/>
    </declare-styleable>
    <!-- 按照比例显示的 FrameLayout -->
    <declare-styleable name="RatioFrameLayout">
        <!-- 宽高比例 -->
        <attr name="sizeRatio" format="string" />
    </declare-styleable>

    <declare-styleable name="CircleImageView">
        <attr name="civ_border_width" format="dimension" />
        <attr name="civ_border_color" format="color" />
        <attr name="civ_border_overlay" format="boolean" />
        <attr name="civ_fill_color" format="color" />
    </declare-styleable>

    <declare-styleable name="FoldTextView">
        <attr name="foldText" format="string" />
        <attr name="unFoldText" format="string" />
        <attr name="foldLine" format="integer" />
        <attr name="tailTextColor" format="color" />
        <attr name="canFoldAgain" format="boolean" />
    </declare-styleable>
    <declare-styleable name="ContrastView">
        <attr name="cv_left_color" format="color" />
        <attr name="cv_right_color" format="color" />
        <attr name="cv_middle_interval" format="dimension" />
        <attr name="cv_left_value" format="float" />
        <attr name="cv_right_value" format="float" />
        <attr name="cv_radius_arc" format="dimension" />
    </declare-styleable>

    <declare-styleable name="PanelView">

    </declare-styleable>
    <declare-styleable name="TrackTextView">
        <attr name="default_color" format="color" />
        <attr name="change_color" format="color" />
    </declare-styleable>

    <declare-styleable name="CheckableGroup">
        <attr name="checkMode" format="enum">
            <enum name="single" value="0" />
            <enum name="multiple" value="1" />
        </attr>
    </declare-styleable>
</resources>