<resources>

    <style name="Theme.AndroidProject" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">?attr/skinColorBackground</item>
        <item name="colorAccent">?attr/skinColorMain</item>
        <item name="skinColorBackground">@color/page_bg</item>
        <item name="skinColorSurface">@color/card_bg</item>
        <item name="skinColorOnMain">@color/white</item>
        <item name="skinColorTextMain">@color/text_main</item>
        <item name="skinColorTextSecond">@color/text_second</item>
    </style>

    <style name="Theme.SkinDemo.Blue" parent="Theme.AndroidProject">
        <item name="colorPrimary">@color/blue_main</item>
        <item name="skinColorMain">@color/blue_main</item>
    </style>

    <style name="Theme.SkinDemo.Red" parent="Theme.AndroidProject">
        <item name="colorPrimary">@color/red_main</item>
        <item name="skinColorMain">@color/red_main</item>
    </style>

    <style name="Theme.SkinDemo.Green" parent="Theme.AndroidProject">
        <item name="colorPrimary">@color/green_main</item>
        <item name="skinColorMain">@color/green_main</item>
    </style>

    <style name="Theme.SkinDemo.Gold" parent="Theme.AndroidProject">
        <item name="colorPrimary">@color/gold_main</item>
        <item name="skinColorMain">@color/gold_main</item>
        <item name="skinColorOnMain">@color/text_main</item>
    </style>

</resources>
