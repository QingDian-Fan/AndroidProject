<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_solid_round_color_surface_radius_top_def"
        android:orientation="vertical"
        android:paddingTop="@dimen/dp_12">

        <TextView
            android:id="@+id/dialog_web_menu_tv_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:alpha="0.3"
            android:gravity="center"
            android:textColor="@color/text_sub_color"
            android:textSize="@dimen/dp_12"
            android:text="网页由wanandroid.com提供"
            android:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_home"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_12"
                    android:src="@mipmap/ic_home"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="回到首页"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_share_article"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_12"
                    android:src="@mipmap/ic_share_article"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="分享到广场"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_collect"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="13dp"
                    android:src="@mipmap/ic_collect"
                    android:tint="@color/text_color" />

                <TextView
                    android:id="@+id/dialog_web_menu_tv_collect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="收藏"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_read_later"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_13"
                    android:src="@mipmap/ic_read_later"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="书签"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_refresh"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_12"
                    android:src="@mipmap/ic_refresh"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="刷新"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_go_top"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="12dp"
                    android:rotation="90"
                    android:src="@mipmap/ic_go_left"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="回到顶部"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_interrupt"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_12"
                    android:src="@mipmap/ic_http_interrupt"
                    android:tint="@color/text_color" />

                <TextView
                    android:id="@+id/dialog_web_menu_tv_interrupt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="网页拦截"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                tools:layout_width="@dimen/dp_100">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/dialog_web_menu_iv_close_activity"
                    android:layout_width="@dimen/dp_48"
                    android:layout_height="@dimen/dp_48"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_press_color_surface_top_radius_max"
                    android:gravity="center"
                    android:padding="@dimen/dp_12"
                    android:src="@mipmap/ic_exit"
                    android:tint="@color/text_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="退出"
                    android:textColor="@color/text_color"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_marginTop="@dimen/dp_12"
            android:background="@color/line_color" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_49">

            <ImageView
                android:id="@+id/dialog_web_menu_iv_dismiss"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_press_color_surface"
                android:padding="@dimen/dp_16"
                android:src="@mipmap/ic_close"
                android:tint="@color/text_color"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/dialog_web_menu_iv_share"
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        android:layout_gravity="center"
                        android:padding="@dimen/dp_16"
                        android:src="@mipmap/ic_share"
                        android:tint="@color/text_color"
                        tools:ignore="UseAppTint" />

                </FrameLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="2" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/dialog_web_menu_iv_setting"
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        android:layout_gravity="center"
                        android:padding="@dimen/dp_16"
                        android:src="@mipmap/ic_setting"
                        android:tint="@color/text_color"
                        tools:ignore="UseAppTint" />

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>
</layout>
