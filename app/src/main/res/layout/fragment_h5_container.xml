<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/dp_30"
        tools:context=".ui.fragment.H5ContainerFragment">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_44"
            android:background="@color/text_blue_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_8"
                android:layout_marginTop="@dimen/dp_6"
                android:layout_marginEnd="@dimen/dp_8"
                android:layout_marginBottom="@dimen/dp_6"
                android:background="@drawable/action_search_bg"
                android:gravity="center_vertical">

                <com.dian.demo.ui.view.CollectView
                    android:id="@+id/cv_collect"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:padding="@dimen/dp_8"
                    app:cv_uncheckedColor="@color/transparent" />

                <EditText
                    android:id="@+id/et_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#00000000"
                    android:ellipsize="end"
                    android:imeOptions="actionGo"
                    android:lines="1"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    android:textSize="@dimen/dp_15"
                    tools:hint="请输入网址" />

                <ImageView
                    android:id="@+id/iv_into"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:padding="@dimen/dp_8"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_into"
                    android:tint="@color/white"
                    tools:ignore="UseAppTint" />

            </LinearLayout>

        </FrameLayout>
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="@dimen/dp_1"
            android:minHeight="@dimen/dp_1"
            android:layout_gravity="bottom"
            android:progressDrawable="@drawable/web_explorer_progress" />
        <com.dian.demo.utils.webview.webview.BrowserWebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_44"
            android:background="@color/bg_common"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="2px"
                android:background="@color/line_color" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/iv_back"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/dp_16"
                    android:layout_marginEnd="@dimen/dp_16"
                    android:padding="@dimen/dp_16"
                    android:src="@mipmap/ic_close" />

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/iv_menu"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/dp_16"
                    android:layout_marginEnd="@dimen/dp_16"
                    android:padding="@dimen/dp_16"
                    android:src="@mipmap/ic_menu" />

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/iv_forward"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/dp_16"
                    android:layout_marginEnd="@dimen/dp_16"
                    android:padding="@dimen/dp_16"
                    android:rotation="180"
                    android:src="@mipmap/ic_back" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</layout>