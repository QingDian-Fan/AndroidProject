<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/smartLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.fragment.MineFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_260"
                android:background="@color/colorPink"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.dian.demo.ui.view.ActionIconView
                    android:id="@+id/iv_user_logo"
                    android:layout_width="@dimen/dp_80"
                    android:layout_height="@dimen/dp_80"
                    android:layout_centerInParent="true"
                    android:layout_marginTop="@dimen/dp_60"
                    android:src="@mipmap/icon_logo" />

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/dp_18"
                    tools:text="GOWEII" />

                <TextView
                    android:id="@+id/tv_user_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    android:text="等级:"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/dp_12" />
            </LinearLayout>

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_coin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_collect"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="我的积分"
                app:bar_leftTextSize="@dimen/dp_15" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_share"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_share_article"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="我的分享"
                app:bar_leftTextSize="@dimen/dp_15" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_collect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_collect"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="我的收藏"
                app:bar_leftTextSize="@dimen/dp_15" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_read_later"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_read_later"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="我的书签"
                app:bar_leftTextSize="@dimen/dp_15" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_read_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_read_record"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="阅读历史"
                app:bar_leftTextSize="@dimen/dp_15" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/sb_todo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/icon_list"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="Todo List" />

            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/sb_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/icon_menu"
                app:bar_leftDrawableSize="@dimen/dp_18"
                app:bar_leftText="功能菜单" />


            <com.dian.demo.ui.view.SettingBar
                android:id="@+id/ll_setting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dp_2"
                app:bar_leftDrawable="@mipmap/ic_setting"
                app:bar_leftDrawableSize="@dimen/dp_16"
                app:bar_leftText="系统设置"
                app:bar_leftTextSize="@dimen/dp_15" />
        </LinearLayout>

    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</layout>