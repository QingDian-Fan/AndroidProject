<?xml version="1.0" encoding="utf-8"?>
<resources>

    <attr name="night_background" format="reference|color" />
    <attr name="night_textColor" format="reference|color" />
    <attr name="night_src" format="reference|color" />
    <attr name="night_shape_solidColor" format="color" />
    <attr name="night_drawableStart" format="reference|color" />
    <attr name="night_drawableEnd" format="reference|color" />
    <attr name="night_drawableTop" format="reference|color" />
    <attr name="night_drawableBottom" format="reference|color" />



    <declare-styleable name="CommonTitleBar">
        <attr name="openStatusBar" format="boolean"/>
        <!-- еЎ«е……зҠ¶жҖҒж Ҹ -->
        <attr name="fillStatusBar" format="boolean" />
        <!-- зҠ¶жҖҒж ҸйўңиүІ -->
        <attr name="statusBarColor" format="color" />
        <!-- зҠ¶жҖҒж ҸжЁЎејҸ -->
        <attr name="statusBarMode" format="enum">
            <enum name="dark" value="0" />
            <enum name="light" value="1" />
        </attr>

        <!-- ж Үйўҳж ҸиғҢжҷҜ еӣҫзүҮжҲ–йўңиүІ -->
        <attr name="titleBarColor" format="color" />
        <!-- ж Үйўҳж Ҹй«ҳеәҰ -->
        <attr name="titleBarHeight" format="dimension" />
        <!-- жҳҫзӨәж Үйўҳж ҸеҲҶеүІзәҝ -->
        <attr name="showBottomLine" format="boolean" />
        <!-- ж Үйўҳж ҸеҲҶеүІзәҝйўңиүІ -->
        <attr name="bottomLineColor" format="color" />
        <!-- еә•йғЁйҳҙеҪұй«ҳеәҰ showBottomLine = falseж—¶жңүж•Ҳ -->
        <attr name="bottomShadowHeight" format="dimension" />

        <!-- е·Ұиҫ№и§Ҷеӣҫзұ»еһӢ -->
        <attr name="leftType">
            <enum name="none" value="0" />
            <enum name="textView" value="1" />
            <enum name="imageButton" value="2" />
            <enum name="customView" value="3" />
            <enum name="imageView" value="4" />

        </attr>
        <!-- TextView ж–Үеӯ—, еҜ№еә”leftType_TextView -->
        <attr name="leftText" format="string" />
        <!-- TextView йўңиүІ, еҜ№еә”leftType_TextView -->
        <attr name="leftTextColor" format="color" />
        <!-- TextView еӯ—дҪ“еӨ§е°Ҹ, еҜ№еә”leftType_TextView -->
        <attr name="leftTextSize" format="dimension" />
        <!-- TextView е·Ұиҫ№еӣҫзүҮ, еҜ№еә”leftType_TextView -->
        <attr name="leftDrawable" format="reference" />
        <!-- TextView е·Ұиҫ№padding, еҜ№еә”leftType_TextView -->
        <attr name="leftDrawablePadding" format="dimension" />
        <!-- ImageView иө„жәҗ, еҜ№еә”leftType_ImageBotton -->
        <attr name="leftImageResource" format="reference" />
        <!-- е·Ұиҫ№иҮӘе®ҡд№үеёғеұҖ, еҜ№еә”leftType_CustomView -->
        <attr name="leftCustomView" format="reference" />

        <!-- еҸіиҫ№и§Ҷеӣҫзұ»еһӢ -->
        <attr name="rightType">
            <enum name="none" value="0" />
            <enum name="textView" value="1" />
            <enum name="imageButton" value="2" />
            <enum name="customView" value="3" />
        </attr>
        <!-- TextView ж–Үеӯ—, еҜ№еә”rightType_TextView -->
        <attr name="rightText" format="string" />
        <!-- TextView йўңиүІ, еҜ№еә”rightType_TextView -->
        <attr name="rightTextColor" format="color" />
        <!-- TextView еӯ—дҪ“еӨ§е°Ҹ, еҜ№еә”rightType_TextView -->
        <attr name="rightTextSize" format="dimension" />
        <!-- ImageView иө„жәҗ, еҜ№еә”rightType_ImageBotton -->
        <attr name="rightImageResource" format="reference" />
        <!-- еҸіиҫ№иҮӘе®ҡд№үеёғеұҖ, еҜ№еә”rightType_CustomView -->
        <attr name="rightCustomView" format="reference" />

        <!-- дёӯй—ҙи§Ҷеӣҫзұ»еһӢ -->
        <attr name="centerType">
            <enum name="none" value="0" />
            <enum name="textView" value="1" />
            <enum name="searchView" value="2" />
            <enum name="customView" value="3" />
        </attr>
        <attr name="centerSearchRightType">
            <enum name="voice" value="0" />
            <enum name="delete" value="1" />
        </attr>
        <!-- TextView ж–Үеӯ—, еҜ№еә”centerType_TextView -->
        <attr name="centerText" format="string" />
        <!-- TextView йўңиүІ, еҜ№еә”centerType_TextView -->
        <attr name="centerTextColor" format="color" />
        <!-- TextView еӯ—дҪ“еӨ§е°Ҹ, еҜ№еә”centerType_TextView -->
        <attr name="centerTextSize" format="dimension" />
        <!-- TextView и·‘й©¬зҒҜж•Ҳжһң, й»ҳи®Өжү“ејҖ, еҜ№еә”centerType_TextView -->
        <attr name="centerTextMarquee" format="boolean" />
        <!-- еӯҗж ҮйўҳTextView ж–Үеӯ—, еҜ№еә”centerType_TextView -->
        <attr name="centerSubText" format="string" />
        <!-- еӯҗж ҮйўҳTextView йўңиүІ, еҜ№еә”centerType_TextView -->
        <attr name="centerSubTextColor" format="color" />
        <!-- еӯҗж ҮйўҳTextView еӯ—дҪ“еӨ§е°Ҹ, еҜ№еә”centerType_TextView -->
        <attr name="centerSubTextSize" format="dimension" />
        <!-- жҗңзҙўиҫ“е…ҘжЎҶжҳҜеҗҰеҸҜиҫ“е…Ҙ -->
        <attr name="centerSearchEditable" format="boolean" />
        <!-- жҗңзҙўжЎҶиғҢжҷҜ -->
        <attr name="centerSearchBg" format="reference" />
        <!-- дёӯй—ҙиҮӘе®ҡд№үеёғеұҖ, еҜ№еә”centerType_CustomView -->
        <attr name="centerCustomView" format="reference" />
    </declare-styleable>

    <!-- жҢүз…§жҜ”дҫӢжҳҫзӨәзҡ„ FrameLayout -->
    <declare-styleable name="RatioFrameLayout">
        <!-- е®Ҫй«ҳжҜ”дҫӢ -->
        <attr name="sizeRatio" format="string" />
    </declare-styleable>

    <declare-styleable name="VideoPlayButton">
        <!-- зәҝжқЎйўңиүІ -->
        <attr name="pb_lineColor" format="color" />
        <!-- зәҝжқЎеӨ§е°Ҹ -->
        <attr name="pb_lineSize" format="integer" />
        <!-- еҠЁз”»ж—¶й—ҙ -->
        <attr name="pb_animDuration" format="integer" />
    </declare-styleable>

    <declare-styleable name="DrawableTextView">
        <attr name="drawable_width" format="dimension"/>
        <attr name="drawable_height" format="dimension"/>
    </declare-styleable>

    <!-- и®ҫзҪ®ж Ҹ -->
    <declare-styleable name="SettingBar">
        <!-- е·Ұиҫ№ -->
        <attr name="bar_leftText" format="string"/>
        <attr name="bar_leftTextColor" format="color" />
        <attr name="bar_leftTextSize" format="dimension" />
        <attr name="bar_leftTextHint" format="string"/>
        <attr name="bar_leftDrawable" format="reference" />
        <attr name="bar_leftDrawablePadding" format="dimension" />
        <attr name="bar_leftDrawableSize" format="dimension" />
        <attr name="bar_leftDrawableTint" format="color" />
        <!-- еҸіиҫ№ -->
        <attr name="bar_rightText" format="string" />
        <attr name="bar_rightTextColor" format="color" />
        <attr name="bar_rightTextSize" format="dimension" />
        <attr name="bar_rightTextHint" format="string"/>
        <attr name="bar_rightDrawable" format="reference" />
        <attr name="bar_rightDrawablePadding" format="dimension" />
        <attr name="bar_rightDrawableSize" format="dimension" />
        <attr name="bar_rightDrawableTint" format="color" />
        <!-- еҲҶеүІзәҝ -->
        <attr name="bar_lineVisible" format="boolean" />
        <attr name="bar_lineDrawable" format="reference|color" />
        <attr name="bar_lineSize" format="dimension" />
        <attr name="bar_lineMargin" format="dimension" />
    </declare-styleable>



</resources>